<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}EventReserve - FIA3-GL{% endblock %}</title>
        
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
        
        <style>
            body { font-family: 'Inter', sans-serif; background-color: #f6f8fa; }
            .navbar-dark { background-color: #0b1120 !important; }
            .main-content { min-height: 80vh; padding: 4rem 0; }
            footer { background: white; border-top: 1px solid #dee2e6; padding: 3rem 0; margin-top: 5rem; }
        </style>

        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold" href="{{ path('app_events') }}">
                    <i class="bi bi-calendar-event-fill me-2 text-primary"></i>EVENT RESERVE
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" href="{{ path('app_events') }}">Explorateur</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">À propos</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        {% if is_granted('ROLE_ADMIN') %}
                            <div class="dropdown">
                                <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                                    <img src="https://ui-avatars.com/api/?name=Hadil+Mokni&background=random" alt="Admin" width="40" height="40" class="rounded-circle border border-2 border-primary">
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li><a class="dropdown-menu-item dropdown-item" href="/admin">Dashboard Admin</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}">Déconnexion</a></li>
                                </ul>
                            </div>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-sm fw-semibold">Se connecter</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        <div class="container main-content">
            {% block body %}{% endblock %}
        </div>

        <footer>
            <div class="container text-center">
                <p class="text-muted mb-0">© 2026 MiniProjet2A - Hadil Mokni (FIA3-GL)</p>
                <small class="text-secondary border-top pt-2 d-block mt-2">Sécurisé par JWT & WebAuthn</small>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
