{% extends 'base.html.twig' %}
{% block title %}Nouvel événement{% endblock %}
{% block body %}
<h1>Créer un événement</h1>
<div class="col-md-6">
    {{ form_start(form) }}
        {% for field in form %}
            <div class="mb-3">
                {{ form_label(field) }}
                {{ form_widget(field, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(field) }}
            </div>
        {% endfor %}
        <button type="submit" class="btn btn-success">Créer</button>
        <a href="{{ path('admin_events') }}" class="btn btn-secondary">Annuler</a>
    {{ form_end(form) }}
</div>
{% endblock %}
