{% extends 'base.html.twig' %}
{% block title %}Dashboard Admin{% endblock %}
{% block body %}
<h1 class="mb-4">Tableau de bord</h1>
<div class="row">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Événements</h5>
                <p class="card-text display-4">{{ total_events }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Réservations</h5>
                <p class="card-text display-4">{{ total_reservations }}</p>
            </div>
        </div>
    </div>
</div>
<h2 class="mt-4">Derniers événements</h2>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Titre</th>
            <th>Date</th>
            <th>Lieu</th>
            <th>Places</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for event in latest_events %}
        <tr>
            <td>{{ event.title }}</td>
            <td>{{ event.date|date('d/m/Y H:i') }}</td>
            <td>{{ event.location }}</td>
            <td>{{ event.seats }}</td>
            <td>
                <a href="{{ path('admin_event_edit', {id: event.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
<a href="{{ path('admin_event_new') }}" class="btn btn-success">+ Nouvel événement</a>
{% endblock %}
