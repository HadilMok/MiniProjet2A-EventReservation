{% extends 'base.html.twig' %}
{% block title %}Événements{% endblock %}
{% block body %}
<h1 class="mb-4">Événements à venir</h1>
<div class="row">
    {% for event in events %}
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            {% if event.image %}
                <img src="{{ asset('uploads/' ~ event.image) }}" class="card-img-top" alt="{{ event.title }}">
            {% endif %}
            <div class="card-body">
                <h5 class="card-title">{{ event.title }}</h5>
                <p class="card-text">{{ event.description|slice(0, 100) }}...</p>
                <p><strong>Date :</strong> {{ event.date|date('d/m/Y H:i') }}</p>
                <p><strong>Lieu :</strong> {{ event.location }}</p>
                <p><strong>Places :</strong> {{ event.seats }}</p>
                <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-primary">Voir détails</a>
            </div>
        </div>
    </div>
    {% else %}
        <p>Aucun événement disponible.</p>
    {% endfor %}
</div>
{% endblock %}
